<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Werkt op telefoon EN Android TV: touch/leanback niet verplicht. -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />

    <!--
      Least privilege: onderstaande worden pas gedeclareerd zodra ze echt
      gebruikt worden. Picture-in-Picture vereist GEEN permission. De
      foreground-service-permissions komen pas met een echte media-
      notificatieservice:
        FOREGROUND_SERVICE, FOREGROUND_SERVICE_MEDIA_PLAYBACK,
        POST_NOTIFICATIONS  (notificatie-speler / achtergrondaudio)
    -->


    <application
        android:name=".StreamFixApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:banner="@drawable/tv_banner"
        android:supportsRtl="true"
        android:theme="@style/Theme.StreamFix"
        tools:targetApi="35">

        <!--
          Sentry auto-init uit: anders draait SentryInitProvider bij opstart
          en crasht zonder DSN. StreamFixApplication doet de gecontroleerde
          init en slaat Sentry over zolang de DSN leeg is.
        -->
        <meta-data
            android:name="io.sentry.auto-init"
            android:value="false" />

        <!-- Google Cast: standaard media-ontvanger via onze OptionsProvider. -->
        <meta-data
            android:name="com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME"
            android:value="nl.streamfix.cast.CastOptionsProvider" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboard|keyboardHidden|navigation|uiMode"
            android:supportsPictureInPicture="true"
            android:theme="@style/Theme.StreamFix.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- Zichtbaar in de Android TV-launcher. -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
